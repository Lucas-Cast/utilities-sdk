{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/gateway/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/gateway",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "credentials-service": {
      "type": "application",
      "root": "apps/credentials-service",
      "entryFile": "main",
      "sourceRoot": "apps/credentials-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/credentials-service/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/modules/database",
      "entryFile": "index",
      "sourceRoot": "libs/modules/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/modules/database/tsconfig.lib.json"
      }
    },
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway/tsconfig.app.json"
      }
    }
  }
}